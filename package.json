{
  "name": "codex-monitor",
  "private": true,
  "version": "0.7.84",
  "packageManager": "pnpm@10.33.0",
  "type": "module",
  "scripts": {
    "sync:material-icons": "node scripts/sync-material-icons.mjs",
    "i18n:compile": "node scripts/compile-paraglide.mjs",
    "postinstall": "pnpm sync:material-icons && pnpm i18n:compile",
    "predev": "pnpm sync:material-icons && pnpm i18n:compile",
    "dev": "vite",
    "prebuild": "pnpm sync:material-icons && pnpm i18n:compile",
    "pretest": "pnpm i18n:compile",
    "build": "tsc && vite build",
    "pretypecheck": "pnpm i18n:compile",
    "prepare:bundled-skills": "node scripts/prepare-bundled-skills.mjs",
    "prepare:codex-runtime": "node scripts/prepare-codex-runtime.mjs",
    "build:appimage": "NO_STRIP=1 tauri build --bundles appimage",
    "doctor": "sh scripts/doctor.sh",
    "doctor:strict": "sh scripts/doctor.sh --strict",
    "doctor:win": "node scripts/doctor.mjs --strict",
    "lint": "eslint . --ext .ts,.tsx",
    "lint:ds": "eslint . --ext .ts,.tsx",
    "codemod:modal-shell": "node scripts/codemods/modal-shell-codemod.mjs",
    "codemod:panel-shell": "node scripts/codemods/panel-shell-codemod.mjs",
    "codemod:toast-shell": "node scripts/codemods/toast-shell-codemod.mjs",
    "codemod:ds:dry": "pnpm codemod:modal-shell -- --dry-run && pnpm codemod:panel-shell -- --dry-run && pnpm codemod:toast-shell -- --dry-run",
    "codemod:ds": "pnpm codemod:modal-shell && pnpm codemod:panel-shell && pnpm codemod:toast-shell",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "preview": "vite preview",
    "tauri": "tauri",
    "pretauri:dev": "pnpm sync:material-icons && pnpm prepare:codex-runtime",
    "tauri:dev": "pnpm doctor:strict && pnpm exec tauri dev",
    "pretauri:build": "pnpm sync:material-icons && pnpm prepare:bundled-skills && pnpm prepare:codex-runtime",
    "tauri:build": "pnpm doctor:strict && node scripts/run-tauri-build.mjs",
    "pretauri:dev:win": "pnpm sync:material-icons && pnpm prepare:codex-runtime",
    "tauri:dev:win": "pnpm doctor:win && pnpm exec tauri dev --config src-tauri/tauri.windows.conf.json",
    "pretauri:build:win": "pnpm sync:material-icons && pnpm prepare:bundled-skills && pnpm prepare:codex-runtime",
    "tauri:build:win": "pnpm doctor:win && node scripts/run-tauri-build.mjs --config src-tauri/tauri.windows.conf.json"
  },
  "dependencies": {
    "@inlang/paraglide-js": "^2.16.0",
    "@inlang/paraglide-vite": "^1.4.0",
    "@pierre/diffs": "^1.0.6",
    "@sentry/react": "^10.36.0",
    "@tanstack/react-virtual": "^3.13.18",
    "@tauri-apps/api": "^2.10.1",
    "@tauri-apps/plugin-dialog": "^2.7.0",
    "@tauri-apps/plugin-notification": "^2.3.3",
    "@tauri-apps/plugin-opener": "^2.5.3",
    "@tauri-apps/plugin-process": "^2.3.1",
    "@tauri-apps/plugin-updater": "^2.10.0",
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/xterm": "^5.5.0",
    "lucide-react": "^0.562.0",
    "prismjs": "^1.30.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "tauri-plugin-liquid-glass-api": "^0.1.6",
    "vscode-material-icons": "^0.1.1"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.10.1",
    "@testing-library/react": "^16.3.2",
    "@types/prismjs": "^1.26.5",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "@vitejs/plugin-react": "^4.6.0",
    "eslint": "^8.57.0",
    "eslint-plugin-react": "^7.36.1",
    "eslint-plugin-react-hooks": "^4.6.2",
    "jsdom": "^27.0.1",
    "typescript": "~5.8.3",
    "vite": "^7.0.4",
    "vitest": "^3.2.4"
  }
}

{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Agent Monitor",
  "version": "0.7.89",
  "identifier": "com.mxyhi.agentmonitor",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "title": "Agent Monitor",
        "width": 1200,
        "height": 700,
        "minWidth": 360,
        "minHeight": 600,
        "dragDropEnabled": true,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "trafficLightPosition": {
          "x": 19,
          "y": 24
        },
        "transparent": true,
        "devtools": true
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": [
          "**/*"
        ]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "externalBin": [
      "binaries/codex-bundled",
      "binaries/codex_monitor_daemon",
      "binaries/codex_monitor_daemonctl"
    ],
    "resources": [
      "git-bundled",
      "generated-bundled-skills"
    ],
    "createUpdaterArtifacts": true,
    "iOS": {
      "frameworks": [
        "libz.tbd",
        "libiconv.tbd"
      ]
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "entitlements": "./Entitlements.plist",
      "infoPlist": "./Info.plist"
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDgyQkE2QzQyN0ZBMDg3RTkKUldUcGg2Qi9RbXk2Z2paNW9ubmpLTE1lWk9xVlpGcElHcXhja3VSYnIvd1U0bXJ0eWhZWjJ2d1gK",
      "endpoints": [
        "https://github.com/mxyhi/AgentMonitor/releases/latest/download/latest.json"
      ]
    }
  }
}
